PORT=3000
NODE_ENV=development

# API / Frontend
CORS_ORIGINS=http://localhost:8081,http://localhost:8080,http://localhost:5173

# Security
JWT_SECRET=replace_with_long_random_secret_for_dev
COOKIE_SECURE=false
TRUST_PROXY=false
ADMIN_BOOTSTRAP_TOKEN=replace_with_one_time_admin_provisioning_secret

# Database
MONGODB_URI=mongodb://localhost:27017/freqvault20

# Google OAuth (User signup/login)
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/user/auth/google/callback
USER_OAUTH_SUCCESS_REDIRECT=http://localhost:8081/files
USER_OAUTH_FAILURE_REDIRECT=http://localhost:8081/signup

# Email notifications / password reset email
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
EMAIL_FROM=FreqVault <your_email@example.com>
USER_PASSWORD_RESET_DEV_FALLBACK=false
USER_PASSWORD_RESET_MIN_INTERVAL_MS=60000
USER_FORGOT_PASSWORD_RATE_LIMIT_MAX=8
USER_RESET_PASSWORD_RATE_LIMIT_MAX=20
USER_ACCOUNT_GUARD_WINDOW_MS=900000
USER_ACCOUNT_GUARD_LOGIN_MAX=5
USER_ACCOUNT_GUARD_REFRESH_MAX=20
USER_ACCOUNT_GUARD_FORGOT_MAX=5
USER_ACCOUNT_GUARD_RESET_MAX=8
USER_ACCOUNT_GUARD_DECRYPT_MAX=10

# Upload controls
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain
UPLOAD_MAX_PDF_BYTES=10485760
UPLOAD_MAX_IMAGE_BYTES=5242880
UPLOAD_MAX_TEXT_BYTES=1048576
ANTIVIRUS_SCAN_ENABLED=false
ANTIVIRUS_SCAN_URL=
ANTIVIRUS_SCAN_TIMEOUT_MS=5000
ANTIVIRUS_INCLUDE_CONTENT=false
ANTIVIRUS_FAIL_CLOSED=false
